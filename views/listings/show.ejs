<% layout("layouts/boiler") -%>
<script>
    const mapt = "<%= process.env.MAP_TOKEN %>";
    const coordinates = <%- JSON.stringify(result.geometry.coordinates) %>;
</script>
<div class="listing-show">

    <div class="listing-card show">

        <img src="<%= result.image.url %>" alt="listing image" class="show-img">

        <div class="listing-info">
             <i><p class="listing-description"><b>Owned by <%= result.owner.username %></b></p></i>
            <h2 class="listing-title"><%= result.title %></h2>

            <p class="listing-description">
                <%= result.description %>
            </p>

            <p class="listing-location">
                📍 <%= result.location %>, <%= result.country %>
            </p>

            <p class="listing-price">
                ₹ <%= result.price.toLocaleString("en-IN") %> / night
            </p>

        </div>
 

     <% if(currentUser && currentUser._id.equals(result.owner._id)){  %> 
        <div class="listing-actions">
             
            <a href="/listing/edit/<%= result.id %>" class="edit-btn">
               Edit
            </a>

            <form action="/listing/delete/<%= result.id %>?_method=DELETE" method="POST">
             
               <button class="delete-btn" onclick="return confirm('Delete this listing?')">
                Delete
               </button>
            </form>

        </div>
       <%  } %>
    </div>

        
</div>


<!-- REVIEW SECTION -->
 <% if(currentUser){  %> 
<div class="review-section">

   <h3 class="review-title">Leave a Review</h3>

   <form action="/listing/<%= result.id %>/reviews" method="post" class="review-form">

        <div class="form-group">
            <label for="ratings">Rating</label>

            <!-- <input 
            type="range" 
            id="ratings" 
            min="1" 
            max="5"
            name="review[ratings]"> -->
           <fieldset class="starability-basic">

  <input type="radio" name="review[ratings]" value="" class="input-no-rate" checked hidden>

  <input type="radio" id="rate1" name="review[ratings]" value="1" required />
  <label for="rate1">1 star</label>

  <input type="radio" id="rate2" name="review[ratings]" value="2" />
  <label for="rate2">2 stars</label>

  <input type="radio" id="rate3" name="review[ratings]" value="3" />
  <label for="rate3">3 stars</label>

  <input type="radio" id="rate4" name="review[ratings]" value="4" />
  <label for="rate4">4 stars</label>

  <input type="radio" id="rate5" name="review[ratings]" value="5" />
  <label for="rate5">5 stars</label>

</fieldset>
        </div>
        <!-- ///////////// -->
          
        <!-- ///////////// -->

        <div class="form-group">
            <label for="description">Comment</label>

            <textarea 
            id="description" 
            name="review[comment]" 
            rows="4" 
            required></textarea>
        </div>

        <button class="submit-btn" type="submit">
            Add Review
        </button>

   </form>
 <% }  %> 
</div>  

<!-- ALL REVIEWS -->
<div class="all-reviews">

    

    <% result.review.forEach((el)=>{ %>
    <h3 class="review-title">User Reviews</h3>
        <div class="review-card">
              <p class="review-rating">
               @<i><b> <%= el.owner.username %> </b></i> says
            </p>
            <p class="starability-result card-text" data-rating=<%= el.ratings %>> </p>

            <p class="review-comment">
                <%= el.comment %>
            </p>

            <p class="review-date">
                <%= el.createdAt.toDateString() %>
            </p>
              <% if(currentUser && currentUser._id.equals(el.owner._id)){  %> 
           <form action="/listing/<%= result.id %>/reviews/<%= el.id %>?_method=DELETE" method="POST">
               <button class="delete-btn" onclick="return confirm('Delete this review?')">
                Delete
              </button>
            </form>  
           <% } %>
        </div>

    <% }) %>

</div>
<div class="map-section">
    <div class="map-card">
        <h3 class="map-title">Where you will be</h3>
        <div id="map"></div>
    </div>
</div>
<script src="/js/map.js"></script>
